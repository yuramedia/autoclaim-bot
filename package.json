{
    "name": "autoclaim-bot",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "bun run deploy && bun run src/index.ts",
        "dev": "bun --watch run src/index.ts",
        "deploy": "bun run src/deploy-commands.ts",
        "format": "bunx oxfmt",
        "format:check": "bunx oxfmt --check",
        "lint": "bunx oxlint",
        "lint:fix": "bunx oxlint --fix"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/he": "^1.2.3",
        "@types/node-cron": "^3.0.11",
        "oxfmt": "^0.47.0",
        "oxlint": "^1.62.0"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "axios": "^1.15.2",
        "cheerio": "^1.2.0",
        "discord.js": "^14.26.3",
        "graphql": "^16.13.2",
        "graphql-request": "^7.4.0",
        "he": "^1.2.0",
        "mongoose": "^9.5.0",
        "node-cron": "^4.2.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "rss-parser": "^3.13.0",
        "universal-speedtest": "^3.0.0"
    }
}
